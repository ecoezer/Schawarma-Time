rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function profileDoc(uid) {
      return get(/databases/$(database)/documents/profiles/$(uid));
    }

    function currentRole() {
      return isSignedIn() && profileDoc(request.auth.uid).exists()
        ? profileDoc(request.auth.uid).data.role
        : null;
    }

    function isAdmin() {
      return currentRole() in ['manager', 'cashier', 'kitchen'];
    }

    function isManager() {
      return currentRole() == 'manager';
    }

    match /restaurant_settings/{docId} {
      allow read: if true;
      allow write: if isManager();
    }

    match /categories/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /products/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /coupons/{docId} {
      allow read: if isSignedIn();
      allow write: if isManager();
    }

    match /profiles/{userId} {
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow read: if (isSignedIn() && request.auth.uid == userId) || isManager();
      allow update: if (isSignedIn() && request.auth.uid == userId) || isManager();
      allow delete: if false;
    }

    match /orders/{orderId} {
      allow create: if isSignedIn()
        && request.resource.data.user_id == request.auth.uid
        && request.resource.data.status == 'pending';
      allow read: if isAdmin() || (isSignedIn() && resource.data.user_id == request.auth.uid);
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
