rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentProfile() {
      return get(/databases/$(database)/documents/profiles/$(request.auth.uid));
    }

    function hasRole(role) {
      return signedIn() && currentProfile().data.role == role;
    }

    function isManager() {
      return hasRole('manager');
    }

    function isStaff() {
      return signedIn() && currentProfile().data.role in ['manager', 'cashier', 'kitchen'];
    }

    match /restaurant_settings/{docId} {
      allow read: if true;
      allow write: if isManager();
    }

    match /categories/{docId} {
      allow read: if true;
      allow write: if isManager();
    }

    match /products/{docId} {
      allow read: if true;
      allow write: if isManager();
    }

    match /coupons/{docId} {
      allow read: if true;
      allow write: if isManager();
    }

    match /profiles/{userId} {
      allow create: if signedIn() && request.auth.uid == userId;
      allow read, update: if signedIn() && (request.auth.uid == userId || isManager());
      allow delete: if false;
    }

    match /orders/{orderId} {
      allow create: if
        request.resource.data.status == 'pending' &&
        request.resource.data.order_number is string &&
        request.resource.data.customer_name is string &&
        request.resource.data.customer_phone is string &&
        request.resource.data.items is list &&
        (
          request.resource.data.user_id == null ||
          (signedIn() && request.resource.data.user_id == request.auth.uid)
        );
      allow get: if true;
      allow list: if isStaff() || (signedIn() && resource.data.user_id == request.auth.uid);
      allow update: if isStaff();
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
